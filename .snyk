# Snyk policy file. The local `ignore:` block is honored by the CLI for
# Open Source (SCA) findings only. Snyk CODE (SAST) findings are NOT ignored
# from this file — they must be ignored in the Snyk dashboard (Project >
# finding > Ignore), which the CLI reads back as server-side Project ignores.
# See https://docs.snyk.io/snyk-cli/commands/ignore
version: v1.5.0

# Open Source (SCA) ignores go here, e.g.:
#   ignore:
#     SNYK-PYTHON-EXAMPLE-12345:
#       - '*':
#           reason: ...
#           expires: 2026-12-31T00:00:00.000Z
ignore: {}

# ── Known Snyk Code false positive (handled in the dashboard, recorded here) ──
# Rule:   javascript/HardcodedNonCryptoSecret
# Path:   frontend/src/api/client.ts:18
# Status: FALSE POSITIVE. Line 18 is
#         `ACCESS_TOKEN_KEY = "donorcrm_access_token"` — a localStorage key NAME
#         used for JWT storage, not a credential. No secret value is hardcoded.
#         Reviewed 2026-06-26. Ignore it via app.snyk.io (Code ignores are not
#         read from this file).

# ── Known Snyk Code false positive (handled in the dashboard, recorded here) ──
# Rule:   javascript/OpenRedirect (CWE-601)
# Path:   frontend/src/pages/Login.tsx — navigate(from, ...)
# Status: FALSE POSITIVE / MITIGATED. `from` is derived from React Router
#         location.state and guarded: only internal absolute paths are honored
#         ("/..."), protocol-relative ("//evil.com") and external URLs are
#         rejected, falling back to "/". See Login.tsx:24-28 (commit e97ff54).
#         Snyk's taint engine does not credit the startsWith("/") sanitizer.
#         Reviewed 2026-06-27. Ignore it via app.snyk.io (Code ignores are not
#         read from this file).
